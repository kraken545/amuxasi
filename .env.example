# Amuxasi — Configuración de API Keys
# Copia este archivo como .env y completa tus keys:
#   cp .env.example .env
#
# Docker lo leerá automáticamente (docker-compose.yml ya lo referencia).

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# OpenRouter (acceso a múltiples modelos)
OPENROUTER_API_KEY=

# Mistral
MISTRAL_API_KEY=
