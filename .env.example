# Amuxasi — Configuración
# Copia este archivo como .env:
#   cp .env.example .env
#
# Docker Compose lo carga automáticamente.

# ── Seguridad ─────────────────────────────────────────────
# Define AMUXASI_TOKEN para proteger la Web UI con autenticación.
# Todas las llamadas API requerirán el header:
#   Authorization: Bearer <token>
# Si está vacío, no hay autenticación (solo red local).
AMUXASI_TOKEN=

# ── API Keys ──────────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# OpenRouter (acceso a múltiples modelos)
OPENROUTER_API_KEY=

# Mistral
MISTRAL_API_KEY=
